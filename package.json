{
  "name": "webcrawl",
  "version": "1.0.0",
  "description": "Adaptive web scraping CLI powered by Playwright CLI and Scrapling",
  "type": "module",
  "bin": {
    "webcrawl": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && mkdir -p dist/bridge && cp src/bridge/*.py dist/bridge/",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "commander": "^13.1.0",
    "csv-stringify": "^6.5.2",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
